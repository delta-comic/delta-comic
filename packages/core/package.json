{
  "name": "@delta-comic/core",
  "version": "0.3.3",
  "description": "空阙虱楼",
  "homepage": "https://github.com/delta-comic/delta-comic",
  "license": "AGPL-3.0-only",
  "author": {
    "name": "wenxig",
    "email": "wenxinguo12@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/delta-comic/delta-comic.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && pnpm pack --out ./dist/pack.tgz",
    "publish:self": "pnpm --filter core publish"
  },
  "devDependencies": {
    "vite": "catalog:",
    "vue-component-type-helpers": "catalog:"
  },
  "peerDependencies": {
    "@delta-comic/model": "workspace:*",
    "@delta-comic/utils": "workspace:*",
    "pinia": "^3.0",
    "vue": "^3.5"
  },
  "release": {
    "tagFormat": "core-${version}"
  },
  "dist": {
    "tarball": "./dist/pack.tgz"
  },
  "readme": "./README.md"
}