{
  "extends": [
    "../../tsconfig.base.json"
  ],
  "compilerOptions": {
    "composite": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "./components.d.ts",
      "./env.d.ts",
      "vue-component-type-helpers",
      "./typed-router.d.ts",
      "vite/client"
    ]
  },
  "vueCompilerOptions": {
    "plugins": [
      "vue-router/volar/sfc-typed-router",
      "vue-router/volar/sfc-route-blocks"
    ]
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "./*.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}