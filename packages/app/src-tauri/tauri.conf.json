{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Delta Comic",
  "version": "3.0.0-next.2",
  "identifier": "org.wenxig.delta-comic",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "vp run --filter app dev:web",
    "beforeBuildCommand": "vp run --filter app build:web"
  },
  "app": {
    "windows": [
      {
        "label": "splash",
        "url": "index.html",
        "title": "Delta Comic",
        "width": 640,
        "height": 420,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "fullscreen": false
      },
      {
        "label": "main",
        "url": "main.html",
        "title": "Delta Comic",
        "width": 800,
        "height": 600,
        "resizable": true,
        "visible": false,
        "focus": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": { "enable": true, "scope": ["$APPLOCALDATA/plugin/**"] }
    },
    "withGlobalTauri": false
  },
  "plugins": { "sql": { "preload": ["sqlite:app.db"] } },
  "bundle": {
    "active": true,
    "targets": "all",
    "homepage": "https://github.com/delta-comic",
    "license": "AGPL-3.0-only",
    "longDescription": "Delta Comic",
    "shortDescription": "Delta Comic",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": { "autoIncrementVersionCode": false, "minSdkVersion": 26 }
  }
}