{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "composite": true,
    "paths": { "@/*": ["./lib/*"] }
  },
  "include": [
    "env.d.ts",
    "components.d.ts",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "lib/**/*.vue",
    "./package.json"
  ]
}