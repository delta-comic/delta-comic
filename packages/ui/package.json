{
  "name": "@delta-comic/ui",
  "version": "0.1.3",
  "description": "空阙虱楼",
  "homepage": "https://github.com/delta-comic/delta-comic",
  "license": "AGPL-3.0-only",
  "author": {
    "name": "wenxig",
    "email": "wenxinguo12@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/delta-comic/delta-comic.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/index2.js",
      "require": "./dist/index2.cjs"
    },
    "./style.css": "./dist/index.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && pnpm pack --out ./dist/pack.tgz",
    "version:major": "pnpm version major --no-git-tag-version || true",
    "version:minor": "pnpm version minor --no-git-tag-version || true",
    "version:patch": "pnpm version patch --no-git-tag-version || true"
  },
  "dependencies": {
    "@lhlyu/vue-virtual-waterfall": "catalog:",
    "@tauri-apps/plugin-shell": "catalog:",
    "@vant/use": "catalog:",
    "@vueuse/core": "catalog:",
    "dayjs": "catalog:",
    "markdown-it": "catalog:",
    "mitt": "catalog:",
    "motion-v": "catalog:",
    "tailwindcss-safe-area-capacitor": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/markdown-it": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "browserslist": "catalog:",
    "lightningcss": "catalog:",
    "tailwindcss": "catalog:",
    "unplugin-vue-components": "catalog:",
    "vite": "catalog:",
    "vue-component-type-helpers": "catalog:"
  },
  "peerDependencies": {
    "@delta-comic/core": "workspace:*",
    "@delta-comic/model": "workspace:*",
    "@delta-comic/utils": "workspace:*",
    "naive-ui": "^2.43",
    "pinia": "^3.0",
    "vant": "^4.9",
    "vue": "^3.5",
    "vue-router": "^5.0"
  },
  "release": {
    "tagFormat": "ui-${version}"
  },
  "dist": {
    "tarball": "./dist/pack.tgz"
  },
  "readme": "./README.md"
}