{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "nodenext",
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "files": [
    "./commitlint.config.ts",
    "./.releaserc.mjs",
    "./script/set-version.mts",
    "./script/update-version.mts"
  ],
  "references": [
    {
      "path": "./packages/app/tsconfig.node.json"
    }
  ]
}