{
  "oxc.path.oxlint": "node_modules/oxlint/bin/oxlint",
  "oxc.lint.run": "onSave",
  "oxc.requireConfig": true,
  "oxc.enable": true,
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "[toml]": { "editor.defaultFormatter": "tamasfe.even-better-toml" },
  "[json]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[vue]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "vue.suggest.componentNameCasing": "alwaysPascalCase",
  "vue.suggest.propNameCasing": "alwaysCamelCase",
  "tailwindCSS.classFunctions": ["twMerge"],
  "tailwindCSS.classAttributes": ["class", "className", "ngClass", "class:list", ":class"]
}